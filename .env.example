# CivitasAI Enterprise Core Environment Blueprint
# Copy this blueprint to .env and configure your production strings

# Overarching System Identity
PROJECT_NAME="CivitasAI: Human Civilization Forecasting Engine"
ENVIRONMENT="production"

# Cryptographic Token Management
# Generate a secure 64-character hex string (e.g., openssl rand -hex 32)
SECRET_KEY="replace-with-your-secure-production-jwt-secret-key-here"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Primary Persistence Credentials (PostgreSQL 16)
POSTGRES_DB="civitas_prod"
POSTGRES_USER="civitas_user"
POSTGRES_PASSWORD="CivitasProductionSecurePassword2026!"
DATABASE_URL="postgresql+asyncpg://civitas_user:CivitasProductionSecurePassword2026!@postgres:5432/civitas_prod"

# Distributed Caching Architecture (Redis 7)
REDIS_URL="redis://redis:6379/0"

# OpenSearch Enterprise Telemetry & Indexing
OPENSEARCH_PASSWORD="CivitasProductionSearchAdminPassword2026!"
OPENSEARCH_URL="http://opensearch:9200"

# AI Domain Gateway Abstraction Tier
PRIMARY_AI_MODEL="mock"  # Options: openai, gemini, anthropic, ollama, mock
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# Next.js Frontend Global URLs
NEXT_PUBLIC_API_URL="https://civitasai.org/api/v1"
